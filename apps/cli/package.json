{
  "name": "@neuve/perf-agent-cli",
  "version": "0.1.2",
  "description": "AI-powered performance analysis CLI for coding agents",
  "keywords": [
    "agents",
    "ai",
    "browser-automation",
    "cli",
    "chrome-devtools",
    "core-web-vitals",
    "performance",
    "web-performance"
  ],
  "license": "FSL-1.1-MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/neuve/perf-agent-cli",
    "directory": "apps/cli"
  },
  "bin": {
    "perf-agent": "./dist/index.js",
    "perf-agent-mcp": "./dist/browser-mcp.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./data/runtime": {
      "types": "./src/data/runtime.ts",
      "import": "./src/data/runtime.ts"
    },
    "./data/recent-reports-atom": {
      "types": "./src/data/recent-reports-atom.ts",
      "import": "./src/data/recent-reports-atom.ts"
    },
    "./data/execution-atom": {
      "types": "./src/data/execution-atom.ts",
      "import": "./src/data/execution-atom.ts"
    },
    "./data/ask-report-atom": {
      "types": "./src/data/ask-report-atom.ts",
      "import": "./src/data/ask-report-atom.ts"
    },
    "./data/flow-storage-atom": {
      "types": "./src/data/flow-storage-atom.ts",
      "import": "./src/data/flow-storage-atom.ts"
    },
    "./data/config-options": {
      "types": "./src/data/config-options.ts",
      "import": "./src/data/config-options.ts"
    }
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "link-global": "pnpm build && pnpm link --global",
    "unlink-global": "pnpm unlink --global",
    "lint": "vp lint && tsc --noEmit",
    "format": "vp fmt",
    "format:check": "vp fmt --check",
    "check": "vp check",
    "test": "vp test",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@agentclientprotocol/claude-agent-acp": "^0.24.2",
    "@effect/atom-react": "4.0.0-beta.35",
    "@effect/platform-node": "4.0.0-beta.35",
    "@github/copilot": "^1.0.12",
    "@google/gemini-cli": "^0.35.3",
    "@hono/node-server": "^1.19.11",
    "@iarna/toml": "^2.2.5",
    "@tanstack/react-query": "^5.80.7",
    "@zed-industries/codex-acp": "^0.10.0",
    "cli-truncate": "^5.2.0",
    "commander": "^13.1.0",
    "detect-terminal": "^2.0.0",
    "effect": "4.0.0-beta.35",
    "figures": "^6.1.0",
    "hono": "^4.12.9",
    "ink": "^6.0.0",
    "ink-link": "^5.0.0",
    "ink-spinner": "^5.0.0",
    "jsonc-parser": "^3.3.1",
    "node-notifier": "^10.0.1",
    "ora": "^9.3.0",
    "picocolors": "^1.1.1",
    "pretty-ms": "^9.3.0",
    "prompts": "^2.4.2",
    "react": "^19.2.4",
    "string-width": "^8.2.0",
    "supports-terminal-graphics": "^0.1.0",
    "which": "^6.0.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-syntax-typescript": "^7.28.6",
    "@neuve/agent": "workspace:*",
    "@neuve/devtools": "workspace:*",
    "@neuve/sdk": "workspace:*",
    "@neuve/shared": "workspace:*",
    "@neuve/supervisor": "workspace:*",
    "@types/node-notifier": "^8.0.5",
    "@types/prompts": "^2.4.9",
    "@types/react": "^19.2.14",
    "babel-plugin-react-compiler": "^1.0.0",
    "typescript": "^5.7.0"
  },
  "optionalDependencies": {
    "oxc-resolver": "^11.19.1"
  },
  "engines": {
    "node": ">=18"
  }
}
