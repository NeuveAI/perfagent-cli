{
  "name": "@neuve/sdk",
  "version": "0.1.2",
  "repository": {
    "type": "git",
    "url": "https://github.com/neuve/perf-agent-cli",
    "directory": "packages/typescript-sdk"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    },
    "./effect": {
      "import": {
        "types": "./dist/effect.d.mts",
        "default": "./dist/effect.mjs"
      }
    }
  },
  "publishConfig": {
    "tag": "alpha"
  },
  "scripts": {
    "lint": "vp lint && tsc --noEmit",
    "format": "vp fmt",
    "format:check": "vp fmt --check",
    "build": "vp pack",
    "check": "vp check",
    "test": "vp test run",
    "test:e2e": "~/.bun/bin/bun tests/e2e.ts",
    "test:watch": "vp test",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@agentclientprotocol/claude-agent-acp": "^0.24.2",
    "@effect/platform-node": "4.0.0-beta.35",
    "@github/copilot": "^1.0.12",
    "@google/gemini-cli": "^0.35.3",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@standard-schema/spec": "^1.1.0",
    "@zed-industries/codex-acp": "^0.10.0",
    "effect": "4.0.0-beta.35"
  },
  "devDependencies": {
    "@neuve/agent": "workspace:*",
    "@neuve/devtools": "workspace:*",
    "@neuve/cookies": "workspace:*",
    "@neuve/shared": "workspace:*",
    "@neuve/supervisor": "workspace:*",
    "@types/bun": "^1.3.11",
    "@types/node": "^22.15.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {},
  "peerDependenciesMeta": {}
}
