# Copy to .env.local and fill in.
# .env.local is gitignored; NEVER commit a real key.

# Google Generative AI API key — required for the LLM-as-judge scorer
# (Gemini 3 Flash) used by `pnpm eval:mind2web`. Get one from
# https://aistudio.google.com/apikey and accept the terms.
GOOGLE_GENERATIVE_AI_API_KEY=

# Optional override of the judge model. Defaults to `gemini-3-flash-preview`.
# EVAL_JUDGE_MODEL=gemini-3-flash-preview

# Optional toggle — set to "false" to skip the LLM-as-judge scorer even if a
# key is present (useful for offline dev loops).
# EVAL_JUDGE_ENABLED=true

# HuggingFace auth — required the first time you populate the Online-Mind2Web
# cache (the dataset is gated). Accept the dataset terms at
# https://huggingface.co/datasets/osunlp/Online-Mind2Web first, then create
# a token at https://huggingface.co/settings/tokens (read scope is enough).
# Once the cache is populated, the token is no longer read.
# HUGGINGFACE_TOKEN=
