{
  "name": "@neuve/evals",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "eval": "evalite run ./evals/smoke.eval.ts",
    "eval:real": "EVAL_RUNNER=real evalite run ./evals/smoke.eval.ts",
    "eval:watch": "evalite watch ./evals/smoke.eval.ts",
    "lint": "vp lint && tsc --noEmit",
